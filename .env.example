# Main configuration file
# Copy this file to .env and adjust the values as needed
# Commented values are defaults and can usually be left unchanged.
# Deployment-specific configuration can also be set in .env.$DEPLOYMENT

####################
# FACILITY VARIABLES
# These should always be changed from the defaults.

## Facility name; used in some naming conventions
FACILITY=facility

## Domain name of the ingestor (don't include https://)
INGESTOR_DOMAIN=ingestor.facility.ch

## Path the the data directory on the docker host
HOST_COLLECTION_PATH=/path/to/data

## Name of the collection. The basename of HOST_COLLECTION_PATH is recommended.
HOST_COLLECTION_NAME=data

## Pin a particular ingestor version (optional)
#INGESTOR_VERSION=latest

## Transfer Method: ExtGlobus (default), None, or S3
#TRANSFER_METHOD=ExtGlobus

### ExtGlobus settings

## Source facility (must be configured in the PSI globus proxy)
GLOBUS_SOURCE_FACILITY=FACILITY

## In most cases globus and the ingestor use the same as HOST_COLLECTION_PATH
#GLOBUS_COLLECTION_ROOT_PATH=$HOST_COLLECTION_PATH

## The facility's id within the identity provider
#OIDC_CLIENT_ID=openem-ingestor-$FACILITY

## Additional parameters for metadata extractors
LIFESCIENCE_EXTRACTOR_ADDITIONAL_PARAMS="--cs 2.7"

# TLS certificates [Proxy]
#TLS_CERT_FILE=/etc/letsencrypt/live/${INGESTOR_DOMAIN}/fullchain.pem
#TLS_KEY_FILE=/etc/letsencrypt/live/${INGESTOR_DOMAIN}/privkey.pem


######################
# DEPLOYMENT VARIABLES
# These are usually set in services/ingestor/config/*/env.*, but are included here for reference.

## Host port for the ingestor (not needed if you proxy from docker)
#INGESTOR_PORT=8080

## base path of the ingestor, appended to ${INGESTOR_DOMAIN} (for proxying)
#INGESTOR_PATH_PREFIX=

## Scicat URLs
#SCICAT_BACKEND_URL=https://scicat.development.psi.ch
#SCICAT_FRONTEND_URL=https://discovery.development.psi.ch
#OIDC_ISSUER=https://kc.development.psi.ch/realms/awi
## Globus destination facility (PSI_QA, PSI_DEV, PSI)
#GLOBUS_TRANSFER_PROXY_URL=https://globus-proxy.development.psi.ch
#GLOBUS_DESTINATION_FACILITY=PSI_DEV

## Ingestor log level
#LOG_LEVEL=Info


###################
# RUNTIME VARIABLES
# These need to be set in the container. They are normally specified in .env.$DEPLOYMENT

## Server mode (debug, release)
#GIN_MODE=debug

## Service user auth (Only needed for 'None' transfer method)
#INGESTOR_SERVICE_USER_NAME=
#INGESTOR_SERVICE_USER_PASS=
