# QA settings
# Don't change this file; override in .env.qa instead.

DEPLOYMENT=qa

# Port to export
INGESTOR_PORT=8081

## Public URL of the ingestor (must match the proxy)
INGESTOR_PATH_PREFIX=/qa

# Debug settings
GIN_MODE=debug
LOG_LEVEL=Debug

# Scicat URLs
SCICAT_BACKEND_URL=https://dacat-qa.psi.ch
SCICAT_FRONTEND_URL=https://discovery-qa.psi.ch
OIDC_ISSUER=https://kc.psi.ch/realms/awi
GLOBUS_TRANSFER_PROXY_URL=https://scicat-globus-proxy-qa.psi.ch
GLOBUS_DESTINATION_FACILITY=PSI_QA
